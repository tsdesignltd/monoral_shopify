{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .mono-download-list {
    margin-top: 3.2rem;
  }

  .mono-download-list h2 {
    margin: 0 0 1rem;
    font-size: 2rem;
    letter-spacing: 0.08em;
  }

  .mono-download-list p {
    margin-top: 0;
  }

  .mono-download-list a[aria-disabled='true'] {
    opacity: 0.55;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {{ section.settings.heading | escape }}
  </h1>
  <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <p>{{ section.settings.lead }}</p>

    <div class="mono-download-list">
      <h2>VIDEO</h2>
      <p>製品紹介動画や使い方の動画をこちらからご覧いただけます。</p>
      <p><a href="#" aria-disabled="true">COMING SOON</a></p>
    </div>

    <div class="mono-download-list">
      <h2>CATALOG</h2>
      <p>製品カタログや資料のPDFをこちらからダウンロードできます。</p>
      <p><a href="#" aria-disabled="true">COMING SOON</a></p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "MONORAL download",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DOWNLOAD"
    },
    {
      "type": "text",
      "id": "lead",
      "label": "Lead",
      "default": "動画やカタログなど、MONORALの資料をこちらからご覧いただけます。"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 28
    }
  ]
}
{% endschema %}
