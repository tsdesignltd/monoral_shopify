{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .mono-product-categories__title {
    margin: 0 0 3rem;
  }

  .mono-product-categories__grid {
    display: grid;
    gap: 2.4rem;
  }

  .mono-product-categories__card {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .mono-product-categories__media {
    aspect-ratio: 1 / 1;
    background: rgba(var(--color-foreground), 0.04);
    overflow: hidden;
  }

  .mono-product-categories__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 180ms ease;
  }

  .mono-product-categories__card:hover img {
    transform: scale(1.03);
  }

  .mono-product-categories__name {
    margin: 1.6rem 0 0;
    font-size: 1.8rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .mono-product-categories__arrow {
    margin-left: 0.4rem;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .mono-product-categories__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8rem;
    }
  }
{%- endstyle -%}

<div class="mono-product-categories page-width section-{{ section.id }}-padding">
  {%- if section.settings.title != blank -%}
    <h2 class="mono-product-categories__title inline-richtext {{ section.settings.heading_size }}">
      {{ section.settings.title }}
    </h2>
  {%- endif -%}

  <div class="mono-product-categories__grid">
    {%- for block in section.blocks -%}
      <a
        class="mono-product-categories__card"
        href="{{ block.settings.link }}"
        {{ block.shopify_attributes }}
      >
        <div class="mono-product-categories__media">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                widths: '360, 540, 720, 900, 1200',
                sizes: '(min-width: 990px) calc((100vw - 10rem) / 3), calc(100vw - 3rem)',
                loading: 'lazy',
                alt: block.settings.title
            }}
          {%- endif -%}
        </div>
        <p class="mono-product-categories__name">
          {{ block.settings.title }}
          <span class="mono-product-categories__arrow">→</span>
        </p>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "MONORAL products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "PRODUCTS"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MONORAL products"
    }
  ]
}
{% endschema %}
